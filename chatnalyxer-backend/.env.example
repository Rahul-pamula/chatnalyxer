# Example .env configuration for WAHA integration

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/chatnalyxer

# WAHA Configuration
WAHA_API_URL=http://localhost:3000
WAHA_API_KEY=  # Optional, leave empty for free version
WAHA_SESSION=default

# OTP Configuration
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
RATE_LIMIT_REQUESTS=3
RATE_LIMIT_WINDOW_MINUTES=60
