# Database Configuration
# For local development, use SQLite:
DATABASE_URL=sqlite:///./chatnalyxer.db
# For production with PostgreSQL:
# DATABASE_URL=postgresql://username:password@host:port/database

# JWT Settings
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OTP Settings
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3

# Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_MINUTES=1

# WhatsApp OTP Service
# For production/testing with real OTPs, use the deployed service:
OTP_SERVICE_URL=https://chatnalyxer-whatsapp.onrender.com
# For local testing without OTP (mock mode), use:
# OTP_SERVICE_URL=http://localhost:3001

# Azure OpenAI (Optional - currently not in use)
# AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
# AZURE_OPENAI_KEY="your-azure-openai-key"
# AZURE_OPENAI_DEPLOYMENT="gpt-35-turbo"
# AZURE_OPENAI_API_VERSION="2024-02-15-preview"

# Google AI (Required for AI analysis)
GOOGLE_API_KEY="your-google-api-key-here"

# Azure Vision (Required for image analysis)
AZURE_VISION_ENDPOINT="https://your-vision-resource.cognitiveservices.azure.com/"
AZURE_VISION_KEY="your-azure-vision-key-here"

# Azure Speech (Required for audio analysis)
AZURE_SPEECH_KEY="your-azure-speech-key-here"
AZURE_SPEECH_REGION="your-region"

# Azure Document Intelligence (Required for PDF/document processing)
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://your-doc-intelligence.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_KEY=your-doc-intelligence-key-here
