# Database
DATABASE_URL=sqlite:///./chatnalyxer.db

# JWT Settings
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OTP Settings
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3

# Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_MINUTES=1

# WhatsApp OTP Service (Deployed on Render)
# For production/testing with real OTPs, use the deployed service:
OTP_SERVICE_URL=https://chatnalyxer-whatsapp.onrender.com

# For local testing without OTP (mock mode), use:
# OTP_SERVICE_URL=http://localhost:3001
