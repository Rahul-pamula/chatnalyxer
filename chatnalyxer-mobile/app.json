{
  "expo": {
    "name": "Chatnalyxer",
    "slug": "chatnalyxer-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/chatnalyxer-logo.png",
    "scheme": "chatnalyxermobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/chatnalyxer-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chatnalyxer.mobile",
      "buildNumber": "1.0.0"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/chatnalyxer-logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.chatnalyxer.mobile",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/chatnalyxer-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/chatnalyxer-logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b6d7e0b5-b04b-4acb-821b-4059a54e214b"
      }
    },
    "owner": "rahul_pamula"
  }
}
